{
  "name": "@review-notes/service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "review-notes-service": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "package": "npm run build:cjs && pkg dist-cjs/index.js --config pkg.config.json --output ../../dist-bin/review-notes-service"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "express": "^4.19.2",
    "simple-git": "^3.25.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/ws": "^8.5.10",
    "@yao-pkg/pkg": "^5.15.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
