<idea-plugin>
    <id>com.peerreviewer.rider</id>
    <name>Virtual Peer Review</name>
    <vendor>Virtual Peer Review</vendor>
    <description>Automated first-pass peer review findings surfaced in a dedicated tool window.</description>

    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Virtual Peer Review"
                    anchor="bottom"
                    factoryClass="com.peerreviewer.PeerReviewerToolWindowFactory"/>
        <applicationConfigurable instance="com.peerreviewer.PeerReviewerConfigurable"
                                  displayName="Virtual Peer Review"
                                  parentId="tools"/>
    </extensions>
</idea-plugin>
