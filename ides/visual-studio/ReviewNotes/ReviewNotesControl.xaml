<UserControl x:Class="ReviewNotes.ReviewNotesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <UserControl.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinWidth" Value="24"/>
        </Style>
        <Style x:Key="CountBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinWidth" Value="20"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,0,0,1" Padding="4">
            <DockPanel>
                <!-- Right side: Logo -->
                <Button x:Name="LogoButton" DockPanel.Dock="Right" Style="{StaticResource ToolbarButton}"
                        ToolTip="matthewratcliffe.com.au" Click="LogoButton_Click"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="MR" FontWeight="Bold" FontSize="11" Foreground="DodgerBlue"/>
                </Button>

                <!-- Left side controls -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="AnalyzeChangesButton" Content="Re-analyse changes"
                            Style="{StaticResource ToolbarButton}" Click="AnalyzeChangesButton_Click"/>
                    <Button x:Name="AnalyzeProjectButton" Content="Re-analyse project"
                            Style="{StaticResource ToolbarButton}" Click="AnalyzeProjectButton_Click"/>
                    <Button x:Name="SettingsButton" Content="&#x2699;"
                            Style="{StaticResource ToolbarButton}" ToolTip="Settings"
                            Click="SettingsButton_Click" FontSize="14"/>
                    <Button x:Name="DetailToggleButton" Content="&#x1F4CB;"
                            Style="{StaticResource ToolbarButton}" ToolTip="Toggle details panel"
                            Click="DetailToggleButton_Click" FontSize="12"/>

                    <Separator Margin="6,2"/>

                    <!-- Severity counts -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                        <Border Style="{StaticResource CountBadge}" Background="#FFE0E0">
                            <TextBlock x:Name="HighCount" Text="H:0" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#CC0000" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Style="{StaticResource CountBadge}" Background="#FFF0D0">
                            <TextBlock x:Name="MediumCount" Text="M:0" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#CC7700" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Style="{StaticResource CountBadge}" Background="#E0F0FF">
                            <TextBlock x:Name="LowCount" Text="L:0" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#0066CC" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Style="{StaticResource CountBadge}" Background="#E8E8E8">
                            <TextBlock x:Name="InfoCount" Text="I:0" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#666666" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <Separator Margin="6,2"/>

                    <!-- Filters -->
                    <TextBlock Text="Severity:" VerticalAlignment="Center" Margin="4,0,2,0"/>
                    <ComboBox x:Name="SeverityFilter" Width="80" SelectedIndex="0"
                              SelectionChanged="SeverityFilter_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="High"/>
                        <ComboBoxItem Content="Medium"/>
                        <ComboBoxItem Content="Low"/>
                        <ComboBoxItem Content="Info"/>
                    </ComboBox>

                    <TextBlock Text="Issue:" VerticalAlignment="Center" Margin="8,0,2,0"/>
                    <ComboBox x:Name="IssueFilter" Width="120" SelectedIndex="0"
                              SelectionChanged="IssueFilter_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                    </ComboBox>

                    <TextBlock Text="Group by:" VerticalAlignment="Center" Margin="8,0,2,0"/>
                    <ComboBox x:Name="GroupByCombo" Width="90" SelectedIndex="0"
                              SelectionChanged="GroupByCombo_SelectionChanged">
                        <ComboBoxItem Content="None"/>
                        <ComboBoxItem Content="Severity"/>
                        <ComboBoxItem Content="File"/>
                        <ComboBoxItem Content="Issue"/>
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <!-- Loading overlay -->
            <TextBlock x:Name="LoadingLabel" Text="Loading findings..."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="Gray" Visibility="Visible"/>

            <!-- Error overlay -->
            <TextBlock x:Name="ErrorLabel" TextWrapping="Wrap" TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="13" Foreground="Red" Visibility="Collapsed"/>

            <!-- Processing overlay -->
            <StackPanel x:Name="ProcessingPanel" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Visibility="Collapsed">
                <ProgressBar x:Name="AnalysisProgressBar" IsIndeterminate="True"
                             Width="300" Height="20" Margin="0,0,0,10"/>
                <TextBlock x:Name="ProcessingLabel" Text="Processing analysis..."
                           TextAlignment="Center" FontSize="13"/>
                <Button x:Name="StopAnalysisButton" Content="Stop Analysis"
                        HorizontalAlignment="Center" Margin="0,10,0,0" Padding="12,4"
                        Click="StopAnalysisButton_Click"/>
            </StackPanel>

            <!-- Findings grid with optional detail panel -->
            <Grid x:Name="FindingsGrid" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition x:Name="DetailColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Findings table -->
                <DataGrid x:Name="FindingsDataGrid" Grid.Column="0"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          CanUserReorderColumns="True" CanUserSortColumns="True"
                          SelectionChanged="FindingsDataGrid_SelectionChanged"
                          MouseDoubleClick="FindingsDataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Severity" Binding="{Binding SeverityDisplay}" Width="80"/>
                        <DataGridTextColumn Header="Issue" Binding="{Binding TitleDisplay}" Width="180"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding MessageDisplay}" Width="*"/>
                        <DataGridTextColumn Header="File" Binding="{Binding FileDisplay}" Width="180"/>
                        <DataGridTextColumn Header="Line" Binding="{Binding LineDisplay}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Grid splitter -->
                <GridSplitter x:Name="DetailSplitter" Grid.Column="0"
                              Width="4" HorizontalAlignment="Right"
                              VerticalAlignment="Stretch" Visibility="Collapsed"
                              Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>

                <!-- Detail panel -->
                <Border x:Name="DetailPanel" Grid.Column="1"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1,0,0,0" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                        <StackPanel>
                            <TextBlock x:Name="DetailTitle" Text="Select a finding"
                                       FontSize="15" FontWeight="Bold" TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="DetailSeverity" FontSize="12" Margin="0,2"/>
                            <TextBlock x:Name="DetailCategory" FontSize="12" Margin="0,2"/>
                            <TextBlock x:Name="DetailFile" FontSize="12" Margin="0,2" TextWrapping="Wrap"/>
                            <TextBlock x:Name="DetailLines" FontSize="12" Margin="0,2"/>
                            <TextBlock x:Name="DetailProvider" FontSize="12" Margin="0,2"/>

                            <Separator Margin="0,10"/>

                            <TextBlock Text="Why it matters" FontWeight="SemiBold"
                                       FontSize="12" Margin="0,6,0,4"/>
                            <TextBox x:Name="DetailMessage" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     BorderThickness="0" Background="Transparent"
                                     FontSize="12" MinHeight="80"/>

                            <Separator Margin="0,10"/>

                            <TextBlock Text="Team Notes (shared via .peer-review/)"
                                       FontWeight="SemiBold" FontSize="12" Margin="0,6,0,4"/>
                            <TextBox x:Name="NotesTextBox" TextWrapping="Wrap"
                                     AcceptsReturn="True" MinHeight="80"
                                     FontSize="12" VerticalScrollBarVisibility="Auto"
                                     TextChanged="NotesTextBox_TextChanged"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="DismissButton" Content="Dismiss"
                                        Padding="8,3" Click="DismissButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
